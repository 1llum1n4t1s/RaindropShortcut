{
  "manifest_version": 3,
  "name": "Raindrop Shortcuts",
  "description": "Raindrop.io のブックマークをすばやく検索・アクセスできる拡張機能",
  "version": "1.0.0",
  "action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    },
    "default_title": "Raindrop Shortcuts",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "permissions": [
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://api.raindrop.io/*",
    "https://raindrop.io/*"
  ]
}
